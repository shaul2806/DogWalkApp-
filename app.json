{
  "expo": {
    "name": "PowSignal",
    "slug": "powsignal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "powsignal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#e8d5c3"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.powsignal.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#e8d5c3"
      },
      "package": "com.powsignal.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#e8d5c3"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
